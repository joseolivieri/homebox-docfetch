# Copy to .env (make env does this) and uncomment + fill what you need.
# Read by docker compose automatically and by the Makefile for native
# `make dev`. Keep values uncommented only when set — an empty assignment
# would override shell-provided env. .env is gitignored — never commit it.

# Homebox instance to develop against (dev collections are disposable —
# the pipeline may tag/attach/enrich anything it sees).
#DOCFETCH_HOMEBOX_URL=

# Homebox API token (Bearer hb_k-…), created in the Homebox UI.
#HOMEBOX_TOKEN=

# OpenRouter key for rerank/vision. Omit to run rules-only
# (no enrichment, no vision intake, no skim).
#OPENROUTER_API_KEY=

# Optional: ntfy bearer token (unused by config.dev.yaml).
#NTFY_TOKEN=

TZ=UTC
